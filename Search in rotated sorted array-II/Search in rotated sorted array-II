class Solution {
    public int search(int[] nums, int target) {

int low=0;
int high=nums.length-1;

while(low<=high)
{
    int mid=(low+high)/2;
    if(nums[mid]==target)
    {

        return mid;
    }
    else if(nums[high]==nums[mid] && nums[mid]==nums[low])
    {
        low=mid+1;
        high=mid-1;
    }
    else if(nums[mid]>=nums[low])
    {
        if((nums[low]<=target) && (nums[mid]>target))
        {
            high=mid-1;
        }
         else
    {
        low=mid+1;
    }
    }
   else
   {
    if(nums[high]>=target && nums[mid]<target)
    {
        low=mid+1;
    }
    else
    {
        high=mid-1;
    }
   }
}



return -1;

    }
}
