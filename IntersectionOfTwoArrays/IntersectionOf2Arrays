class Solution
 {
    public int[] intersection(int[] nums1, int[] nums2)
    {
ArrayList<Integer> list=new ArrayList<>();
int i=0;

while(i!=nums1.length)
{
  int j=nums2.length-1;
    while(j!=-1)
    {
    if(nums1[i] ==nums2[j])
    {
        if(!list.contains(nums1[i]))
        {
        list.add(nums1[i]);
        }

break;
    }
    else
    {
        j--;
    }
}
i++;
}

int[] arr=new int[list.size()];
for(int k=0;k<list.size();k++)
{
arr[k]=list.get(k);
}

return arr;
    }
}
