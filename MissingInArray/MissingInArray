class Solution {
    int missingNum(int arr[]) {
        // code here

        ArrayList<Integer> list=new ArrayList<>();

        for(int i=0;i<arr.length;i++)
        {
            list.add(arr[i]);
        }

        Collections.sort(list);

        for(int i=0;i<arr.length;i++)
        {
          if(list.get(i)!=i+1)
          {
              return i+1;
          }



        }

        return arr.length+1;

    }
}
