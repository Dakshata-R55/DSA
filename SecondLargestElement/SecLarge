class Solution {
    public int getSecondLargest(int[] arr) {
        // code here
        int tem=arr[0];
        for(int i=1;i<arr.length;i++)
        {
            if(tem<arr[i])
            {
                tem=arr[i];
            }
        }

        int ret=-1;
        for(int j=0;j<arr.length;j++)
        {
            if(arr[j]!=tem&&ret<arr[j])
            {
                ret=arr[j];
            }
        }

        return ret;
    }
}
