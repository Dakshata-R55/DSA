class Solution {
    int upperBound(int[] arr, int target) {
        // code here
     int ret=arr.length;
     int low=0;
     int high=arr.length-1;
    while(low<=high)
    {
        int mid=(low+high)/2;
        if(arr[mid]>target)
        {
            ret=mid;
            high=mid-1;
        }

        else
        {
            low=mid+1;
        }
    }

    return ret;
    }
}
