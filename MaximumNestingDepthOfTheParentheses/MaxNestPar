class Solution {
    public int maxDepth(String s)
     {

int start=0;
int max=0;

for(int i=0;i<s.length();i++)
{
    if(s.charAt(i)=='(')
    {
        start++;
        if(max<start)
        {
            max=start;
        }
    }
    else if(s.charAt(i)==')')
    {

        start--;

    }
}

return max;



    }
}
