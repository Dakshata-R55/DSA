class Solution {
    static boolean isPrime(int n) {
        // code here
        int check=0;
        boolean ret=false;
        for(int i=1;i<=n;i++)
        {
        if(n%i==0)
        {
            check++;
        }
    }

        if(check==2)
        {
            ret=true;
        }

        return ret;
    }
}
