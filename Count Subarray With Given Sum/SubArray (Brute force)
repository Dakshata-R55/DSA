class Solution {
    public int subarraySum(int[] nums, int k) {


        int count =0;
for(int i=0;i<nums.length;i++)
{
    int tem=Integer.MIN_VALUE;
    for(int j=i;j<nums.length;j++)
    {
        tem=tem+nums[j];
        if(tem==k)
        {
            count++;
            break;
        }
    }
}

return count;

    }
}
