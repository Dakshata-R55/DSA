class Solution {
    public void sortColors(int[] nums) {
     for(int i=0;i<nums.length;i++)
     {
        for(int j=0;j<nums.length;j++)
        {
            if(nums[i]<nums[j])
            {
            int tem=nums[i];
            nums[i]=nums[j];
            nums[j]=tem;
            }
        }
     }
    }
}
