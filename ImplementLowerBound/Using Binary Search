class Solution {
    int lowerBound(int[] arr, int target) {
        // code here

        int low=0;
        int high=arr.length-1;
        int ret=arr.length;
        while(low<=high)
        {
            int mid=(low+high)/2;
            if(arr[mid]>=target)
            {
                ret= mid;
                high=mid-1;
            }
            else if(arr[mid]<target)
            {
                low=mid+1;

            }


        }
        return ret;

    }
}
