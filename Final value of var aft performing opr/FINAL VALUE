class Solution {
    public int finalValueAfterOperations(String[] operations) {

int ret=0;

for(int i=0;i<operations.length;i++)
{
    if(operations[i].equals("--X"))
    {
        ret=ret-1;
    }
    else if(operations[i].equals("X--"))
    {

        ret=ret-1;
}
else
{
    ret=ret+1;
}
}
return ret;


    }
}
