class Solution {

    // Function to return length of longest subsequence of consecutive integers.
    public int longestConsecutive(int[] arr) {
        // code here
        Set<Integer> set=new HashSet<>();
        for(int i=0;i<arr.length;i++)
        {
            set.add(arr[i]);
        }
         int max=0;



            for(int i=0;i<arr.length;i++)
            {
                int num=arr[i];
                int tem=0;
            while(set.contains(num))
            {
                   num++;
                   tem++;

            }

            if(tem>max)
            {
                max=tem;
            }
        }
        return max;

    }
}
