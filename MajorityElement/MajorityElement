class Solution {
    public int majorityElement(int[] nums) {
        List<Integer> list=new ArrayList<>();

        for(int val:nums)
        {
            list.add(val);
        }
int div=nums.length/2;

Collections.sort(list);
int count=0;
int ret=list.get(0);
for(int i=0;i<list.size()-1;i++)
{
    if(list.get(i).equals(list.get(i+1)))
    {
count++;
if(count>=div)
{
    ret= list.get(i);
    break;
}
    }
    else
    {
        count=0;
    }
}
return ret;

    }
}
