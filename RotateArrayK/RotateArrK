class Solution
{
    static void rotateArr(int arr[], int d)
    {
        // code here

        int tem[]=new int[arr.length];

        d=d%arr.length;


        for(int i=0;i<arr.length;i++)
        {

            if(i-d<0)
            {
                tem[arr.length+(i-d)]=arr[i];
            }
            else
            {
           tem[i-d]=arr[i];
            }
        }

         for(int i=0;i<arr.length;i++)
        {
            arr[i]=tem[i];
        }







    }






}
